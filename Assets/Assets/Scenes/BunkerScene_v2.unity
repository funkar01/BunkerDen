MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1093074551}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 38326f8c1ca3338439457bf848fdf31b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BunkerTools.MissionCoordinator
  Dialogue1Text: Welcome to mission agent, I am your mission coordinator.
  Dialogue2Text: There should be a generator and electric switch, power on the Bunker!
  ObjectiveHUDText: Locate the generator and power on the Bunker!
  Scene4Dialogue1Text: Mind the poisonous gases trapped inside, you need to hurry
    and find the evidence before your breath runs out
  Scene4Dialogue2Text: look for the main command room
  Scene4ObjectiveText: Look for the main command room
  Scene4Dialogue1Clip: {fileID: 0}
  Scene4Dialogue2Clip: {fileID: 0}
  Scene5Dialogue1Text: Great, now search for the evidence, it should be the biometric
    key which looks like a hard drive.
  Scene5Dialogue2Text: 
  Scene5ObjectiveText: Search for the biometric key!
  Scene5Dialogue1Clip: {fileID: 0}
  Scene5Dialogue2Clip: {fileID: 0}
  Scene6Dialogue1Text: The secret code is 'heart of India'.
  Scene6ObjectiveText: Check for the 'Heart of India'!
  Scene6Dialogue1Clip: {fileID: 0}
  Scene7Dialogue1Text: Well done, you found the secret button at the Heart of India
    of Indian map!
  Scene7ObjectiveText: Explore the unlocked locker!
  Scene7Dialogue1Clip: {fileID: 0}
  Scene8Dialogue1Text: Bravo, you have found the Key, now exit the bunker ASAP
  Scene8ObjectiveText: Exit the bunker quickly!
  Scene8Dialogue1Clip: {fileID: 0}
